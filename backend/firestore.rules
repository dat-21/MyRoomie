rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Trong giai đoạn dev: cho phép backend đọc/ghi qua service account
    // Production: thêm rules chặt hơn theo từng collection
    match /{document=**} {
      allow read, write: if false; // Frontend không được truy cập trực tiếp
    }
  }
}
